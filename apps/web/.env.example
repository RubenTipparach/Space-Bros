# Copy to .env.local and fill in real values.

# ---- Database (Chunk 4a) ---------------------------------------------------
# Neon: https://console.neon.tech — create a project, copy the pooled
# connection string (the one with `-pooler` in the hostname). Example:
#   postgres://user:pass@ep-cool-moon-123.eu-central-1.aws.neon.tech/spacebros?sslmode=require
DATABASE_URL=

# ---- Auth (Chunk 4b, not required yet) -------------------------------------
# CLERK_PUBLISHABLE_KEY=
# CLERK_SECRET_KEY=

# ---- Galaxy --------------------------------------------------------------
# Seed string for the one persistent galaxy. Change BEFORE the first
# migration; changing it after colonies exist is a world-breaking event.
GALAXY_SEED=space-bros-prime
GALAXY_STAR_COUNT=12000
